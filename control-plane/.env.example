NODE_ENV=production
PORT=17883
PUBLIC_BASE_URL=https://api.fangxinbanmeet.com
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=12h

MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_USER=livekit_control
MYSQL_PASSWORD=replace-with-db-password
MYSQL_DATABASE=livekit_control
MYSQL_CONNECTION_LIMIT=10
AUTO_MIGRATE=false

LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
LIVEKIT_DEFAULT_REGION=hk
LIVEKIT_SIGNAL_HK=wss://hk.livekit.fangxinbanmeet.com
LIVEKIT_SIGNAL_SG=wss://sg.livekit.fangxinbanmeet.com
LIVEKIT_SIGNAL_CN=wss://cn.livekit.fangxinbanmeet.com

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-immediately
ADMIN_BOOTSTRAP_DISPLAY_NAME=System Admin
